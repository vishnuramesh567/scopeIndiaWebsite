@model List<ScopeIndiaWebsite.Models.Course>

@{
    ViewBag.Title = "My Courses";
}

<div class="container py-5">
    <div class="text-center mb-5 animate__animated animate__fadeInDown">
        <h1 class="display-4 fw-bold" style="color: #4CAF50;">My Courses 🎓</h1>
        <p class="lead text-muted">
            Here are all the courses you have successfully enrolled in.
        </p>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 animate__animated animate__fadeIn">
            <div class="alert alert-info rounded-pill px-5 d-inline-block">
                <i class="bi bi-info-circle-fill me-2"></i> You haven’t signed up for any courses yet.
            </div>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 animate__animated animate__fadeInUp">
            @foreach (var course in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-lg border-0 rounded-4 course-card">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="course-icon me-3">
                                    <i class="bi bi-book-fill fs-2 text-white"></i>
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-0">@course.CourseName</h5>
                            </div>
                            <hr class="my-3">
                            <ul class="list-unstyled text-muted flex-grow-1">
                                <li class="mb-2">
                                    <i class="bi bi-clock me-2 text-success"></i>
                                    <strong>Duration:</strong> @course.Duration
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-currency-rupee me-2 text-success"></i>
                                    <strong>Fee:</strong> ₹@course.Fee
                                </li>
                                <li>
                                    <i class="bi bi-calendar-check me-2 text-success"></i>
                                    <strong>Status:</strong> Enrolled
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    <div class="text-center mt-5 animate__animated animate__fadeInUp">
        <a href="/Student/Dashboard" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">
            <i class="bi bi-arrow-left me-2"></i> Go to Dashboard
        </a>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');

    body {
        font-family: 'Poppins', sans-serif;
        background-color: #f0f2f5;
    }

    .course-card {
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
    }

        .course-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.1) !important;
        }

    .course-icon {
        background-color: #4CAF50;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />