@model ScopeIndiaWebsite.Models.Student

@{
    ViewData["Title"] = "Edit Profile";
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | SCOPE INDIA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        body {
            background-color: #f0f2f5;
            font-family: 'Poppins', sans-serif;
            padding-top: 3rem;
            padding-bottom: 3rem;
        }

        .card {
            border: none;
        }

        .form-label {
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: #495057;
        }

        .form-control,
        .form-select {
            border-radius: 0.5rem;
            transition: all 0.3s ease;
        }

            .form-control:focus,
            .form-select:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            }

        .profile-avatar {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border: 5px solid #fff;
        }

        .upload-btn {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .gender-options .form-check {
            display: inline-block;
            margin-right: 1.5rem;
        }
    </style>
</head>

<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="text-center mb-5 animate__animated animate__fadeInDown">
                    <h1 class="display-4 fw-bold text-dark">Manage Your Profile</h1>
                    <p class="lead text-muted">
                        Update your personal information to keep your details current.
                    </p>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i><strong>Success!</strong> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="card shadow-lg border-0 rounded-4 animate__animated animate__fadeInUp">
                    <div class="card-body p-4 p-md-5">
                        <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.Id)

                            <div class="text-center mb-4">
                                <div class="position-relative d-inline-block">
                                    @if (Model.Avatar != null && Model.Avatar.Length > 0)
                                    {
                                        var base64 = Convert.ToBase64String(Model.Avatar);
                                        var imgSrc = String.Format("data:image/png;base64,{0}", base64);
                                        <img src="@imgSrc" alt="Current Profile Picture" class="rounded-circle profile-avatar shadow" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle profile-avatar bg-light d-flex align-items-center justify-content-center border">
                                            <i class="bi bi-person-fill text-muted fs-1"></i>
                                        </div>
                                    }
                                    <label for="avatarFile" class="btn btn-primary btn-sm rounded-circle upload-btn shadow-sm">
                                        <i class="bi bi-camera"></i>
                                        <input type="file" name="avatarFile" id="avatarFile" class="d-none" />
                                    </label>
                                </div>

                                <small class="d-block text-muted mt-2">Update your profile photo</small>
                            </div>

                            <hr class="my-4" />

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label asp-for="reg_first_name" class="form-label"><i class="bi bi-person me-2 text-primary"></i>First Name</label>
                                    <input asp-for="reg_first_name" class="form-control" />
                                    <span asp-validation-for="reg_first_name" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="reg_last_name" class="form-label"><i class="bi bi-person-fill me-2 text-primary"></i>Last Name</label>
                                    <input asp-for="reg_last_name" class="form-control" />
                                    <span asp-validation-for="reg_last_name" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="Gender" class="form-label"><i class="bi bi-gender-ambiguous me-2 text-primary"></i>Gender</label>
                                    <div class="gender-options">
                                        <div class="form-check form-check-inline">
                                            <input type="radio" asp-for="Gender" value="Male" class="form-check-input" />
                                            <label class="form-check-label">Male</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input type="radio" asp-for="Gender" value="Female" class="form-check-input" />
                                            <label class="form-check-label">Female</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input type="radio" asp-for="Gender" value="Other" class="form-check-input" />
                                            <label class="form-check-label">Other</label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="Gender" class="text-danger d-block"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="reg_date_of_birth" class="form-label"><i class="bi bi-calendar-date me-2 text-primary"></i>Date of Birth</label>
                                    <input asp-for="reg_date_of_birth" type="date" class="form-control" />
                                    <span asp-validation-for="reg_date_of_birth" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="reg_mobile_number" class="form-label"><i class="bi bi-telephone-fill me-2 text-primary"></i>Phone Number</label>
                                    <input asp-for="reg_mobile_number" class="form-control" />
                                    <span asp-validation-for="reg_mobile_number" class="text-danger"></span>
                                </div>
                               
                                <div class="col-12">
                                    <label class="form-label"><i class="bi bi-heart me-2 text-primary"></i>Select your Hobbies</label>
                                    <div class="row hobbies-options">
                                        @{
                                            var hobbies = new[] { "reading", "sports", "music", "travel", "gaming" };
                                            // FIX: Change the delimiter to a single comma ","
                                            var modelHobbies = Model.reg_hobbies?.Split(new[] { "," }, StringSplitOptions.RemoveEmptyEntries) ?? new string[0];
                                            foreach (var hobby in hobbies)
                                            {
                                                <div class="col-auto">
                                                    <div class="form-check">
                                                        <input type="checkbox" class="form-check-input" name="Hobbies"
                                                               value="@hobby" @(modelHobbies.Contains(hobby) ? "checked" : "") />
                                                        <label class="form-check-label">@hobby</label>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="col-12">
                                    <h5 class="mt-4 mb-3 text-secondary"><i class="bi bi-geo-alt-fill me-2"></i>Address</h5>
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label asp-for="reg_country" class="form-label">Country</label>
                                            <select asp-for="reg_country" id="Country" class="form-select">
                                                <option value="">Select Country</option>
                                            </select>
                                            <span asp-validation-for="reg_country" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label asp-for="reg_state" class="form-label">State</label>
                                            <select asp-for="reg_state" id="State" class="form-select">
                                                <option value="">Select State</option>
                                            </select>
                                            <span asp-validation-for="reg_state" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label asp-for="reg_city" class="form-label">City</label>
                                            <select asp-for="reg_city" id="City" class="form-select">
                                                <option value="">Select City</option>
                                            </select>
                                            <span asp-validation-for="reg_city" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 text-center d-grid gap-2 d-sm-block">
                                <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold me-sm-3">
                                    <i class="bi bi-save me-2"></i>Save Changes
                                </button>
                                <a href="/Student/Dashboard" class="btn btn-outline-secondary btn-lg px-5">
                                    <i class="bi bi-arrow-left me-2"></i>Go to Dashboard
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            var selectedCountry = '@Html.Raw(Model.reg_country)';
            var selectedState = '@Html.Raw(Model.reg_state)';
            var selectedCity = '@Html.Raw(Model.reg_city)';

            function loadCountries() {
                $.get("https://countriesnow.space/api/v0.1/countries/states", function (data) {
                    var countrySelect = $("#Country");
                    countrySelect.empty().append("<option value=''>Select Country</option>");
                    data.data.forEach(function (countryData) {
                        countrySelect.append("<option value='" + countryData.name + "'>" + countryData.name + "</option>");
                    });

                    if (selectedCountry) {
                        countrySelect.val(selectedCountry).trigger("change");
                    }
                });
            }

            $("#Country").change(function () {
                var countryName = $(this).val();
                var stateSelect = $("#State");
                stateSelect.empty().append("<option value=''>Select State</option>");
                $("#City").empty().append("<option value=''>Select City</option>");

                if (countryName) {
                    $.post("https://countriesnow.space/api/v0.1/countries/states", { country: countryName }, function (res) {
                        res.data.states.forEach(function (val) {
                            stateSelect.append("<option value='" + val.name + "'>" + val.name + "</option>");
                        });
                        if (selectedState && countryName === selectedCountry) {
                            stateSelect.val(selectedState).trigger("change");
                        }
                    });
                }
            });

            $("#State").change(function () {
                var stateName = $(this).val();
                var countryName = $("#Country").val();
                var citySelect = $("#City");
                citySelect.empty().append("<option value=''>Select City</option>");

                if (stateName) {
                    $.post("https://countriesnow.space/api/v0.1/countries/state/cities",
                        { country: countryName, state: stateName },
                        function (res) {
                            res.data.forEach(function (val) {
                                citySelect.append("<option value='" + val + "'>" + val + "</option>");
                            });
                            if (selectedCity && stateName === selectedState) {
                                citySelect.val(selectedCity);
                            }
                        });
                }
            });

            loadCountries();
        });
    </script>
</body>
</html>