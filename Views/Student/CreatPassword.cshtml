@model int    
@{
    Layout = "_Layout";
}
<h2>Create New Password</h2>
<form asp-action="CreateNewPassword" method="post">
    <input type="hidden" name="id" value="@Model" />
    <label>New Password</label>
    <input name="newPwd" type="password" required />
    <label>Confirm Password</label>
    <input name="confirmPwd" type="password" required />
    <button type="submit">Set Password</button>
</form>

@if (TempData["msg"] != null) { <p>@TempData["msg"]</p> }
