<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ScopeIndiaWebsite</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/About.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/Student.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/ScopeIndiaWebsite.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
    <header style="background-color:#0b0b3d; position:relative; padding:27px ;">

        <div style="position:absolute; top:15px; left:30px;">
            <img src="~/images/scopeindia-logo.png" alt="Scope India Logo" style="width:170px;">
        </div>

        <div style="position:absolute; top:15px; right:25px; ">
            <img src="~/images/google-rating-scope-india.png" alt="Google Rating" style="width:200px;">
        </div>

        <!-- ✅ Navigation Bar -->
        @* <nav style="display: flex; justify-content: end; align-items:center; gap: 30px; margin-top: 100px; font-size: 16px; font-weight: bold;"> *@
        <nav style="display:flex;  align-items:end; gap:20px; margin-top:100px; font-size:13px; font-weight:bold;justify-content:end">
            <a class="nav-link" asp-controller="Home" asp-action="Index" style="color: white; text-decoration: none;">HOME</a>
            <a class="nav-link" asp-controller="Home" asp-action="About" style="color:white;text-decoration:none;">ABOUT US</a>
            <a class="nav-link" asp-controller="Home" asp-action="Contact" style="color:white;text-decoration:none">CONTACT</a>

            <a class="nav-link" asp-controller="Student" asp-action="Register" style="color: white; text-decoration: none;">REGISTRATION</a>
            <a class="nav-link" asp-controller="Student" asp-action="Login" style="color:white;text-decoration:none;">LOGIN</a>
            
        </nav>

    </header> 
    
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer id="container_footer">
        <p>We are located at Technopark&nbsp;TVM | Thampanoor&nbsp;TVM | Kochi,&nbsp;Kerala | Nagercoil,&nbsp;Tamil&nbsp;Nadu</p>
        <p>
            <a href="tel:+919745936073" title="Call SCOPE INDIA Technopark, Trivandrum, Kerala 09745936073">9745936073&nbsp;(TPK)</a>
            <a href="tel:+919745936073" title="Call SCOPE INDIA Trivandrum, Kerala 09745936073">9745936073&nbsp;(TVM)</a>
            <a href="tel:+917592939481" title="Call SCOPE INDIA Kochi, Kerala 07592939481">7592939481&nbsp;(EKM)</a>
            <a href="tel:+918075536185" title="Call SCOPE INDIA Nagercoil, Kerala 08075536185">8075536185&nbsp;(NGL)</a>
            <a href="mailto:info@scopeindia.org?subject=I want to know more about courses" title="Email SCOPE INDIA">info@scopeindia.org</a>
        </p>
        <p class="footer_line">
            All Rights Reserved
            <a href="https://www.suffixesolutions.com/" title="Suffix E Solutions, a trusted IT Partner, the parent company of SCOPE INDIA" target="_blank">
                SCOPE INDIA &amp; SUFFIX E SOLUTIONS PRIVATE LIMITED
            </a>
            ©&nbsp;2007-2025
            <span>|</span>
            <a href="privacy-policy.html" title="SCOPE INDIA Privacy Policy">
                Privacy Policy
            </a>
            <span>|</span>
            <a href="blog.html" title="SCOPE INDIA Privacy Policy">
                Blog
            </a>
        </p>
    </footer>
   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

</body>
</html>
